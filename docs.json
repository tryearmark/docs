{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Earmark",
  "colors": {
    "primary": "#059669",
    "light": "#34d399",
    "dark": "#059669"
  },
  "fonts": {
    "family": "Geist"
  },
  "favicon": "/logo/favicon.png",
  "logo": {
    "light": "/logo/dark.png",
    "dark": "/logo/light.png"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Product guide",
        "groups": [
          {
            "group": "Getting started",
            "icon": "rocket",
            "pages": [
              "index",
              "getting-started/platforms",
              "getting-started/setup-guide",
              "getting-started/calendar",
              "getting-started/run-your-first-meeting"
            ]
          },
          {
            "group": "Earmark basics",
            "icon": "book-open",
            "pages": [
              "earmark-basics/transcription",
              "earmark-basics/artifacts",
              "earmark-basics/templates",
              "earmark-basics/command-menu",
              "earmark-basics/meeting-history",
              "earmark-basics/temporary-meetings",
              "earmark-basics/workspaces",
              {
                "group": "Integrations",
                "expanded": false,
                "pages": [
                  "integrations/overview",
                  "integrations/cursor",
                  "integrations/linear",
                  "integrations/v0",
                  "integrations/codex"
                ]
              }
            ]
          },
          {
            "group": "Using Earmark",
            "icon": "map",
            "pages": [
              "using-earmark/before-a-meeting",
              "using-earmark/during-a-meeting",
              "using-earmark/after-a-meeting"
            ]
          },
          {
            "group": "Customization",
            "icon": "sliders",
            "pages": [
              "customization/personalization",
              "customization/custom-templates",
              "customization/multilingual"
            ]
          },
          {
            "group": "Troubleshooting",
            "icon": "wrench",
            "pages": [
              "troubleshooting/live-transcription",
              "troubleshooting/app-disconnected",
              "troubleshooting/desktop-deep-linking",
              "troubleshooting/capture-session-limit"
            ]
          },
          {
            "group": "Security and privacy",
            "icon": "shield",
            "pages": [
              "security-and-privacy"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "groups": [
          {
            "group": "Changelog",
            "icon": "calendar",
            "pages": [
              "changelog"
            ]
          }
        ]
      }
    ],
    "global": {}
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://www.tryearmark.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Launch app",
      "href": "https://app.tryearmark.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "seo": {
    "indexing": "all",
    "metatags": {
      "og:site_name": "Earmark Docs",
      "twitter:card": "summary_large_image",
      "keywords": "meeting productivity, AI meeting assistant, live transcription, meeting artifacts, botless transcription, botless meeting tool",
      "robots": "index, follow",
      "language": "en",
      "category": "Technology"
    }
  },
  "footer": {
    "socials": {
      "website": "https://www.tryearmark.com"
    }
